generator client {
    provider = "prisma-client"
    output   = "generated"
}

datasource db {
    provider = "postgresql"
}

model Users {
    id            String        @id @default(ulid())
    name          String
    email         String        @unique
    emailVerified Boolean       @default(false)
    image         String?
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @default(now()) @updatedAt
    sessions      Sessions[]
    accounts      Accounts[]
    members       Members[]
    invitations   Invitations[]
    teamMembers   TeamMembers[]
    scanJobs      ScanJobs[]
    emailSettings EmailSettings?
    dropboxAccount DropboxAccounts?
    todos         Todos[]
}

model Sessions {
    id                   String         @id @default(ulid())
    expiresAt            DateTime
    token                String         @unique
    createdAt            DateTime       @default(now())
    updatedAt            DateTime       @updatedAt
    ipAddress            String?
    userAgent            String?
    userId               String
    user                 Users          @relation(fields: [userId], references: [id], onDelete: Cascade)
    activeOrganizationId String?
    activeOrganization   Organizations? @relation(fields: [activeOrganizationId], references: [id])
    activeTeamId         String?
    activeTeam           Teams?         @relation(fields: [activeTeamId], references: [id])

    @@index([userId, token])
}

model Accounts {
    id                    String    @id @default(ulid())
    accountId             String
    providerId            String
    userId                String
    user                  Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    @@index([userId])
}

model Verifications {
    id         String   @id @default(ulid())
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime @default(now())
    updatedAt  DateTime @default(now()) @updatedAt

    @@index([identifier])
}

model Organizations {
    id                String              @id @default(ulid())
    name              String
    slug              String              @unique
    logo              String?
    metadata          String?
    createdAt         DateTime            @default(now())
    updatedAt         DateTime            @updatedAt
    members           Members[]
    invitations       Invitations[]
    organizationRoles OrganizationRoles[]
    teams             Teams[]
    sessions          Sessions[]
}

model Members {
    id             String        @id @default(ulid())
    userId         String
    user           Users         @relation(fields: [userId], references: [id], onDelete: Cascade)
    organizationId String
    organization   Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    role           String
    createdAt      DateTime      @default(now())
    updatedAt      DateTime      @updatedAt

    @@unique([organizationId, userId])
    @@index([userId])
    @@index([organizationId])
}

model Invitations {
    id             String        @id @default(ulid())
    email          String
    inviterId      String
    inviter        Users         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
    organizationId String
    organization   Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    role           String
    status         String
    teamId         String?
    team           Teams?        @relation(fields: [teamId], references: [id])
    createdAt      DateTime      @default(now())
    updatedAt      DateTime      @updatedAt
    expiresAt      DateTime

    @@index([organizationId])
    @@index([email])
}

model OrganizationRoles {
    id             String        @id @default(ulid())
    organizationId String
    organization   Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    role           String
    permission     String
    createdAt      DateTime      @default(now())
    updatedAt      DateTime      @updatedAt

    @@index([organizationId])
}

model Teams {
    id             String        @id @default(ulid())
    name           String
    organizationId String
    organization   Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    createdAt      DateTime      @default(now())
    updatedAt      DateTime      @updatedAt
    teamMembers    TeamMembers[]
    invitations    Invitations[]
    sessions       Sessions[]

    @@index([organizationId])
}

model TeamMembers {
    id        String   @id @default(ulid())
    teamId    String
    team      Teams    @relation(fields: [teamId], references: [id], onDelete: Cascade)
    userId    String
    user      Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([teamId, userId])
    @@index([teamId])
    @@index([userId])
}

// Dropbox Scanner Models

model DropboxAccounts {
    id           String   @id @default(ulid())
    userId       String   @unique
    user         Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
    accessToken  String
    refreshToken String?
    expiresAt    DateTime?
    accountId    String
    email        String?
    createdAt    DateTime @default(now())
    updatedAt    DateTime @default(now()) @updatedAt
}

model ScanJobs {
    id              String          @id @default(ulid())
    userId          String
    user            Users           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
    // File info
    originalName    String
    contentHash     String
    mimeType        String
    fileSize        Int
  
    // Processing status
    status          String          @default("pending") // pending, processing, completed, failed
    progress        Int             @default(0) // 0-100
    stage           String?         // upload, ai-analysis, dropbox, docketwise, email
  
    // Client/Matter assignment
    suggestedClient String?
    selectedClient  String?         // Docketwise contact ID
    clientName      String?         // Human-readable client name
    suggestedMatter String?
    selectedMatter  String?         // Docketwise matter ID
    matterName      String?         // Human-readable matter name
    aiConfidence    Float?
  
    // AI Analysis
    isRfe           Boolean         @default(false)
    aiAnalysis      Json?           // Full Gemini analysis result
    renamedFileName String?         // AI-generated smart file name (DocType_Client_Date.ext)

    // Pipeline flags
    uploadToDocketwise Boolean      @default(true)  // User checkbox — upload to Docketwise?
    queueFilePath      String?                       // Dropbox /Scans/Queue path for resume

    // Results
    dropboxPath     String?
    docketwiseDocId String?
  
    // Error tracking
    errorMessage    String?
    retryCount      Int             @default(0)
  
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @default(now()) @updatedAt
    fileMetadata    FileMetadata?
    emailLogs       EmailLog[]

    @@index([userId, status])
    @@index([contentHash])
    @@index([createdAt])
}

model Matters {
    id           String          @id @default(ulid())
    docketwiseId String          @unique
    clientName   String
    matterType   String?
    description  String?
    status       String          @default("active")
    lastSyncedAt DateTime        @default(now())
    createdAt    DateTime        @default(now())
    updatedAt    DateTime        @default(now()) @updatedAt

    files        FileMetadata[]

    @@index([clientName])
}

model FileMetadata {
    id           String    @id @default(ulid())
    scanJobId    String    @unique
    scanJob      ScanJobs  @relation(fields: [scanJobId], references: [id])

    // Storage locations
    dropboxPath  String
    docketwiseDocId String?
    matterId     String?
    matter       Matters?  @relation(fields: [matterId], references: [id])

    // File details
    clientName   String
    fileName     String
    fileType     String
    uploadedAt   DateTime  @default(now())
    uploadedBy   String

    @@index([clientName])
    @@index([matterId])
    @@index([uploadedAt])
}

model EmailSettings {
    id             String   @id @default(ulid())
    userId         String   @unique
    user           Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

    recipients     String[] // Array of email addresses
    notifyOnUpload Boolean  @default(true)
    notifyOnError  Boolean  @default(true)

    smtpHost       String?
    smtpPort       Int?
    smtpUser       String?
    smtpPass       String? // Encrypted

    createdAt      DateTime @default(now())
    updatedAt      DateTime @default(now()) @updatedAt
}

model EmailLog {
    id           String   @id @default(ulid())
    scanJobId    String?
    scanJob      ScanJobs? @relation(fields: [scanJobId], references: [id], onDelete: SetNull)

    recipients   String[] // All recipients this was sent to
    subject      String
    status       String   @default("pending") // pending, sent, failed
    errorMessage String?

    // File / context metadata
    fileName     String?
    fileSize     Int?
    fileType     String?
    clientName   String?
    matterName   String?
    template     String?  // upload-success, upload-error, summary

    sentAt       DateTime @default(now())
    createdAt    DateTime @default(now())

    @@index([scanJobId])
    @@index([sentAt])
    @@index([status])
}

model Todos {
    id          String    @id @default(ulid())
    title       String
    description String?
    dueTime     DateTime?
    status      String    @default("pending")
    userId      String
    user        Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
}
